<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/size_2"
    android:padding="@dimen/size_5"
    app:cardCornerRadius="@dimen/size_10"
    app:cardElevation="@dimen/size_2"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgCategory"
            android:layout_width="@dimen/size_150"
            android:layout_height="@dimen/size_150"
            android:scaleType="centerCrop"
            android:src="@drawable/app_logo" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/text_date"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/size_10"
                android:gravity="center"
                android:text="1"
                android:textSize="@dimen/fontsize_16"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/size_5"
                android:layout_marginTop="@dimen/size_5"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/image_remove_qty"
                    android:layout_width="@dimen/size_35"
                    android:layout_height="@dimen/size_35"
                    android:padding="@dimen/size_5"
                    app:srcCompat="@drawable/ic_baseline_indeterminate_check_box_24"
                    app:tint="@color/colorPrimary"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/text_qty"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:minWidth="@dimen/size_50"
                    android:text="1"
                    android:textSize="@dimen/fontsize_16"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/image_add_qty"
                    android:layout_width="@dimen/size_35"
                    android:layout_height="@dimen/size_35"
                    android:padding="@dimen/size_5"
                    app:srcCompat="@drawable/ic_baseline_add_box_24"
                    app:tint="@color/colorPrimary"/>
            </LinearLayout>
        </LinearLayout>


    </LinearLayout>

</androidx.cardview.widget.CardView>
