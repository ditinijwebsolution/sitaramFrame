<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginHorizontal="@dimen/size_5"
    android:padding="@dimen/size_10"
    app:cardCornerRadius="@dimen/size_15"
    app:cardElevation="@dimen/size_2"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@color/white">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/imgCategory"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintDimensionRatio="h,2:3"
                    android:scaleType="fitXY"
                    android:src="@drawable/app_logo"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <!-- <androidx.appcompat.widget.AppCompatImageView
                 android:id="@+id/imgCategory"
                 android:layout_width="match_parent"
                 android:layout_height="@dimen/size_150"
                 android:scaleType="centerCrop"
                 android:src="@drawable/app_logo" />-->

            <TextView
                android:id="@+id/mTxtFrameNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/fontsize_12"
                tools:text="frame Number"
                android:textColor="@color/black"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/size_5"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_to_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/size_5"
                android:text="@string/add_to_cart"
                app:cornerRadius="@dimen/size_15"
                android:textColor="@color/white"/>

            <TextView
                android:id="@+id/mTxtOutOfStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/fontsize_12"
                android:text="@string/lbl_no_stock"
                android:textColor="@color/colorError"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/size_5"
                android:visibility="gone"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/img_download"
            android:layout_width="@dimen/size_30"
            android:layout_height="@dimen/size_30"
            android:src="@drawable/ic_downloads"
            android:contentDescription="@null"
            android:layout_gravity="end"
            android:padding="@dimen/size_5"
            android:layout_marginEnd="@dimen/size_15"
            android:layout_marginTop="@dimen/size_10"/>
    </FrameLayout>

</androidx.cardview.widget.CardView>
